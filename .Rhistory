library(dplyr)
library(tidyr)
moda <- function(x) {
ux <- unique(x[!is.na(x)])
ux[which.max(tabulate(match(x, ux)))]
}
house_prices_final <- house_prices_limpio |>
mutate(
across(
where(is.numeric),
~ replace_na(.x, median(.x, na.rm = TRUE))
),
across(
where(is.character) | where(is.factor),
~ replace_na(.x, get_moda(.x))
)
)
moda <- function(x) {
ux <- unique(x[!is.na(x)])
ux[which.max(tabulate(match(x, ux)))]
}
house_prices_final <- house_prices_limpio |>
mutate(
across(
where(is.numeric),
~ replace_na(.x, median(.x, na.rm = TRUE))
),
across(
where(is.character) | where(is.factor),
~ replace_na(.x, moda(.x))
)
)
get_moda <- function(x) {
ux <- unique(x[!is.na(x)])
if(length(ux) == 0) return(NA) # Manejo de columnas vacías
ux[which.max(tabulate(match(x, ux)))]
}
# 2. Ejecutar la imputación
house_prices_final <- house_prices_limpio |>
mutate(
# Para numéricas
across(
where(is.numeric),
~ replace_na(.x, median(.x, na.rm = TRUE))
),
# Para categóricas (usando el nombre correcto: get_moda)
across(
where(is.character) | where(is.factor),
~ replace_na(.x, get_moda(.x))
)
)
rlang::last_trace()
get_moda <- function(x) {
x <- x[!is.na(x)]
if (length(x) == 0) return(NA_character_) # Retorna NA tipo texto para evitar conflictos
ux <- unique(x)
as.character(ux[which.max(tabulate(match(x, ux)))]) # Forzamos a character
}
# 2. Ejecución con manejo de tipos
house_prices_final <- house_prices_limpio |>
# Paso previo: Convertir factores a character para evitar problemas de niveles
mutate(across(where(is.factor), as.character)) |>
mutate(
# Imputar numéricas
across(
where(is.numeric),
~ replace_na(.x, median(.x, na.rm = TRUE))
),
# Imputar categóricas
across(
where(is.character),
~ replace_na(.x, get_moda(.x))
)
)
