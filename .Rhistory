get_moda <- function(v) {
v <- na.omit(v)
uniqv <- unique(v)
uniqv[which.max(tabulate(match(v, uniqv)))]
}
HP_mode <- house_prices_limpio|>
mutate(
across(
where(is.character) | where(is.factor),
~ ifelse(is.na(.x), get_moda(.x), .x)
)
)
# Comprobación definitiva: ¿Queda algún NA en todo el dataframe?
sum(is.na(HP_mode))
